# SprintMind AI Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ==============================================================================
# Execution Environment
# Values: development | production
# ==============================================================================
ENVIRONMENT=development

# ==============================================================================
# Server Configuration
# PORT is injected automatically by Render — do not set manually on Render.
# ==============================================================================
APP_TITLE=SprintMind AI Backend
APP_VERSION=1.0.0

# ==============================================================================
# CORS — Allowed frontend origins
# JSON list format: ["https://your-app.vercel.app","http://localhost:5173"]
# In development the default (localhost:5173) is used automatically.
# On Render, set this to include your Vercel deployment URL.
# ==============================================================================
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ==============================================================================
# Supabase
# Found in: Supabase Dashboard → Project Settings → API
# ==============================================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ==============================================================================
# Google Gemini AI
# Found in: Google AI Studio → API Keys
# ==============================================================================
GEMINI_API_KEY=
