# SprintMind AI Frontend - Environment Variables Configuration
# Copy this file to '.env' and fill in your local developer secrets.

# URL of the hosted Supabase project instance
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co

# Public anonymous key for client-side queries and authentication
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Base URL of the running FastAPI backend server (local development default)
VITE_API_URL=http://localhost:8000
